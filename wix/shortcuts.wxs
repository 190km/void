<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <!-- Desktop shortcut -->
    <DirectoryRef Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="a1b2c3d4-e5f6-7890-abcd-ef1234567890">
        <Shortcut
          Id="DesktopVoidShortcut"
          Name="Void"
          Description="Infinite Canvas Terminal"
          Target="[INSTALLDIR]void.exe"
          WorkingDirectory="INSTALLDIR" />
        <RegistryValue
          Root="HKCU"
          Key="Software\Void"
          Name="DesktopShortcut"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Start Menu shortcut -->
    <DirectoryRef Id="ProgramMenuFolder">
      <Directory Id="VoidProgramMenuFolder" Name="Void">
        <Component Id="StartMenuShortcut" Guid="b2c3d4e5-f6a7-8901-bcde-f12345678901">
          <Shortcut
            Id="StartMenuVoidShortcut"
            Name="Void"
            Description="Infinite Canvas Terminal"
            Target="[INSTALLDIR]void.exe"
            WorkingDirectory="INSTALLDIR" />
          <RemoveFolder Id="CleanupStartMenu" On="uninstall" />
          <RegistryValue
            Root="HKCU"
            Key="Software\Void"
            Name="StartMenuShortcut"
            Type="integer"
            Value="1"
            KeyPath="yes" />
        </Component>
      </Directory>
    </DirectoryRef>

    <!-- Register components -->
    <Feature Id="ShortcutsFeature" Title="Shortcuts" Level="1">
      <ComponentRef Id="DesktopShortcut" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>
  </Fragment>
</Wix>
